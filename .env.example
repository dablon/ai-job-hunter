# =============================================================================
# Job Hunter (Minimax Edition) - Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# AI Providers (choose one)
# -----------------------------------------------------------------------------

# Anthropic Claude API (alternative)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Minimax API (recommended - cost effective)
# Get your key from: https://platform.minimax.io/
# This is the DEFAULT provider
MINIMAX_API_KEY=

# OpenCode CLI (alternative - requires opencode installed)
# Install with: npm install -g opencode-ai
# Optional: specify model in config.json (opencode_model field)

# -----------------------------------------------------------------------------
# Email Notifications (Gmail SMTP)
# -----------------------------------------------------------------------------

EMAIL_SENDER=your-email@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx  # Gmail App Password (not your regular password)
EMAIL_RECIPIENT=your-email@gmail.com

# -----------------------------------------------------------------------------
# Discord Notifications (alternative)
# -----------------------------------------------------------------------------

# Get your webhook URL from: Discord Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Optional: Override config.json via environment
# -----------------------------------------------------------------------------

# PROFILE=your profile text
# KEYWORDS=python developer,backend engineer,devops
